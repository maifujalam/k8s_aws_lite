apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: letsencrypt-prod-cluster-issuer
spec:
  acme:
    server: https://acme-v02.api.letsencrypt.org/directory
    email: sk.maifujalam@gmal.com
    privateKeySecretRef:
      name: letsencrypt-cert
    solvers:
    - dns01:
        route53:
          region: us-east-1          # Keep it constatnt at all cost, otherwise it will fail to create the certificate
          hostedZoneID: Z03481592NF3WUPSPBKDG   # 👈 replace with your Route53 hosted zone ID
          accessKeyID: {{ACCESS_KEY_ID}}
          secretAccessKeySecretRef:
            name: route53-credentials-secret
            key: secret-access-key
